# Copy this file to .env and add your own credentials.
# Never commit .env to GitHub.

# Required for live departure boards.
# This is the OpenLDBWS / Darwin token, usually shaped like:
# nnnnnnnn-nnnn-nnnn-nnnn-nnnnnnnnnnnn
NATIONAL_RAIL_DARWIN_TOKEN=your_darwin_live_departure_board_token

# Optional: Data Portal credentials are not used by the live board endpoint.
# Keep them here only if you later add Data Portal feed features.
NATIONAL_RAIL_USERNAME=your_username
NATIONAL_RAIL_PASSWORD=your_password

# Optional: TfL API key for local proxy requests through /api/tfl.
TFL_APP_KEY=your_tfl_app_key
TFL_APP_ID=

PORT=8000
