# Copy this file to .env and add your own credentials.
# Never commit .env to GitHub.

# Preferred for live departure boards:
NATIONAL_RAIL_DARWIN_TOKEN=your_darwin_live_departure_board_token

# Optional fallback if your National Rail account gives username/password.
# The server will use these only if NATIONAL_RAIL_DARWIN_TOKEN is empty.
NATIONAL_RAIL_USERNAME=your_username
NATIONAL_RAIL_PASSWORD=your_password

PORT=8000
